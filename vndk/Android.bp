cc_prebuilt_library_shared {
    name: "libssl",
    vendor: true,
    strip: {
        none: true,
    },
    target: {
        android_arm: {
            srcs: ["libssl.so"],
        },
    },
    compile_multilib: "32",
    check_elf_files: false,
}